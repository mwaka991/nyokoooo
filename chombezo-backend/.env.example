# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key-here

# JWT Configuration
JWT_SECRET=your-jwt-secret-here

# FastLipa Payment Provider
FASTLIPA_API_URL=https://api.fastlipa.com
FASTLIPA_API_KEY=your-fastlipa-api-key-here

# DEVELOPMENT MODE: Mock payments for testing (no real FastLipa needed)
MOCK_PAYMENTS=false

# Premium Settings
PREMIUM_PRICE=1000
PREMIUM_DURATION_MINUTES=60

# Application Settings
NODE_ENV=development
PORT=3001
